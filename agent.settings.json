{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Runtime allowlist for the BeamtimeHero embedded agent. Loaded by `claude -p --settings agent.settings.json` in server/claude_cli_backend.py. NOT auto-loaded by any other Claude Code session in this directory.",
  "permissions": {
    "allow": [
      "Bash(./scripts/beamtimehero --help)",
      "Bash(./scripts/beamtimehero -h)",
      "Bash(./scripts/beamtimehero --list-profiles)",
      "Bash(./scripts/beamtimehero ref *)",
      "Bash(./scripts/beamtimehero bth --help)",
      "Bash(./scripts/beamtimehero bth *)",
      "Read(*)"
    ],
    "deny": [
      "Bash(./scripts/beamtimehero spec-write *)",
      "Bash(./scripts/beamtimehero db *)",
      "Bash(./scripts/beamtimehero tool *)",
      "Bash(./scripts/beamtimehero spec-read *)",
      "Bash(./scripts/beamtimehero spec-file *)",
      "Bash(./scripts/beamtimehero s3df *)",
      "Bash(./scripts/beamtimehero slack *)",
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(mv *)",
      "Bash(cp *)",
      "Bash(git *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(ssh *)",
      "Edit",
      "Write",
      "WebFetch",
      "WebSearch",
      "Agent"
    ]
  }
}
