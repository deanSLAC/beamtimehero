{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(./scripts/beamtimehero --help)",
      "Bash(./scripts/beamtimehero -h)",
      "Bash(./scripts/beamtimehero bth --help)",
      "Bash(./scripts/beamtimehero bth ref *)",
      "Bash(./scripts/beamtimehero bth tool *)",
      "Bash(./scripts/beamtimehero bth spec-read *)",
      "Read(*)"
    ],
    "deny": [
      "Bash(./scripts/beamtimehero bth spec-write *)",
      "Bash(./scripts/beamtimehero bth db *)",
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(mv *)",
      "Bash(cp *)",
      "Bash(git *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(ssh *)",
      "Edit",
      "Write",
      "WebFetch",
      "WebSearch",
      "Agent"
    ]
  }
}
