# Stanford AI API Gateway
API_KEY=your_api_key_here

# Optional: Override the default model
# STANFORD_MODEL=claude-4-5-sonnet

# Slack integration
SLACK_BOT_TOKEN=xoxb-your-token
SLACK_APP_TOKEN=xapp-your-token
SLACK_CHANNEL_ID=your-channel-id

# App configuration
BASE_PATH=/beamtimehero

# Tools configuration
# Path to playground repo (for blmcp/bldata_analysis imports)
# PLAYGROUND_ROOT=/path/to/playground

# Tools mode: "mcp" (full tool schemas) or "cli" (progressive discovery)
# TOOLS_MODE=mcp
