# Stanford AI API Gateway
API_KEY=your-api-key
STANFORD_MODEL=claude-4-5-sonnet

# Slack integration (optional -- app works without these)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_CHANNEL_ID=your-channel-id

# App configuration
BASE_PATH=/beamtimehero

# Data directories (set these to the correct paths on the beamline computer)
# BL_SCAN_DIR=/sdf/group/ssrl/isaac/data/data
# BL_LOGS_DIR=/sdf/group/ssrl/isaac/data/logs

# Tools configuration
# Tools mode: "cli" (progressive discovery, default) or "mcp" (full tool schemas)
# TOOLS_MODE=cli
