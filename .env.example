# Pick the LiteLLM gateway claude-code routes through: stanford | slac | default
LLM_GATEWAY=stanford

# Path to the `claude` binary (Claude Code CLI). Override if not on PATH.
CLAUDE_BIN=claude

# --- SLAC gateway ---
SLAC_BASE_URL=https://ai-api.slac.stanford.edu
SLAC_API_KEY=
SLAC_ANTHROPIC_DEFAULT_OPUS_MODEL=us.anthropic.claude-opus-4-6-v1
SLAC_ANTHROPIC_DEFAULT_SONNET_MODEL=us.anthropic.claude-sonnet-4-6
SLAC_ANTHROPIC_DEFAULT_HAIKU_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0
SLAC_CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS=1

# --- Stanford gateway ---
STANFORD_BASE_URL=https://aiapi-prod.stanford.edu
STANFORD_API_KEY=
STANFORD_ANTHROPIC_DEFAULT_SONNET_MODEL=claude-4-6-opus
STANFORD_DISABLE_PROMPT_CACHING=1
STANFORD_CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS=1

# Slack integration (optional -- app works without these)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_LLM_CHANNEL_ID=your-llm-log-channel-id
SLACK_USERS_CHANNEL_ID=your-users-channel-id

# App configuration
# Leave BASE_PATH unset (or empty) to serve at /. Set to e.g. /beamtimehero
# when deploying behind a reverse proxy that expects a path prefix.
# BASE_PATH=

# Data directories (defaults: /data/fifteen → latest subfolder, /usr/local/lib/spec.log/logfiles)
# The app only works against a configured data directory. When BL_SCAN_DIR
# doesn't resolve, the UI shows a "not configured — ask staff" banner (chat
# still works) instead of silently serving packaged demo data.
# BL_SCAN_DIR=/data/fifteen
# BL_LOGS_DIR=/usr/local/lib/spec.log/logfiles

# Demo sample-data fallback. BTH defaults this to 1 (disabled) so demo data
# never masquerades as live. Set 0 to re-enable upstream's fallback for a
# local UI demo with no real beamline data.
# BEAMTIMEHERO_NO_SAMPLE_FALLBACK=1

# MLflow tracing -- disabled by default. To enable on the beamline machine,
# request a service-account token from the ISAAC team (issued from the
# `bth-bot` Authentik account, member of the `admin` group) and set:
#   MLFLOW_ENABLED=1
#   MLFLOW_TRACKING_TOKEN=<bth-bot-token>
# For local development you can use a personal portal token instead.
MLFLOW_ENABLED=0
# MLFLOW_TRACKING_URI=https://isaac.slac.stanford.edu/mlflow/api/external
# MLFLOW_TRACKING_TOKEN=
