# Stanford AI API Gateway
API_KEY=your-api-key
STANFORD_MODEL=claude-4-6-opus

# Slack integration (optional -- app works without these)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_LLM_CHANNEL_ID=your-llm-log-channel-id
SLACK_USERS_CHANNEL_ID=your-users-channel-id

# App configuration
# Leave BASE_PATH unset (or empty) to serve at /. Set to e.g. /beamtimehero
# when deploying behind a reverse proxy that expects a path prefix.
# BASE_PATH=

# Data directories (defaults: /data/fifteen → latest subfolder, /usr/local/lib/spec.log/logfiles)
# BL_SCAN_DIR=/data/fifteen
# BL_LOGS_DIR=/usr/local/lib/spec.log/logfiles

# Tools configuration
# Tools mode: "cli" (progressive discovery, default) or "mcp" (full tool schemas)
# TOOLS_MODE=cli

# MLflow tracing -- disabled by default. To enable on the beamline machine,
# request a service-account token from the ISAAC team (issued from the
# `bth-bot` Authentik account, member of the `admin` group) and set:
#   MLFLOW_ENABLED=1
#   MLFLOW_TRACKING_TOKEN=<bth-bot-token>
# For local development you can use a personal portal token instead.
MLFLOW_ENABLED=0
# MLFLOW_TRACKING_URI=https://isaac.slac.stanford.edu/mlflow/api/external
# MLFLOW_TRACKING_TOKEN=
